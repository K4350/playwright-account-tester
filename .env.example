# Environment Configuration
# Copy this file to .env and update with your values

# URLs
LOGIN_URL=https://your-login-url.example.com/u/login
LOGOUT_URL=https://your-logout-url.example.com/logout

# API Endpoint
API_ENDPOINT=/your-api-path/customer/

# Test Data
TEST_DATA_FILE=./testData/YourTestData.xlsx

# Timeouts (in milliseconds)
NAVIGATION_TIMEOUT=30000
LOGIN_TIMEOUT=25000
LOGOUT_TIMEOUT=10000
ACTION_TIMEOUT=5000
TEST_TIMEOUT=60000

# Test Configuration
RETRY_ATTEMPTS=3
WORKERS=3
SKIP_LOGOUT=false

# Report Configuration
REPORT_PATH=./test-results/test-summary-report
